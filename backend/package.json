{
  "name": "construescala-hospitality-backend",
  "version": "1.0.0",
  "description": "Backend API for CONSTRUESCALA Hospitality marketplace",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
