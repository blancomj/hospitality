    "@sentry/profiling-node": "^10.67.0",
    "@types/multer": "^2.2.0",
    "bull": "^4.16.5",
    "bullmq": "^5.80.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "firebase-admin": "^14.2.0",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "mysql2": "^3.12.0",
    "sharp": "^0.35.3",
    "zod": "^3.24.2"
