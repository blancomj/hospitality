# ============================================
# CONSTRUESCALA Hospitality — Backend
#
# Este archivo es una PLANTILLA y se versiona en git.
# NUNCA escribas aquí valores reales: cópialo a `.env` (ignorado por git)
# y pon ahí las credenciales verdaderas.
# ============================================

# Server
PORT=3001
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_password_mysql
DB_NAME=construescala_hospitality

# Base de datos exclusiva para pruebas (npm run test).
TEST_DB_NAME=construescala_test

# JWT — secretos de sesión
# Genera cada uno con:  openssl rand -hex 64
JWT_ACCESS_SECRET=genera-uno-con-openssl-rand-hex-64
JWT_REFRESH_SECRET=genera-otro-distinto-con-openssl-rand-hex-64
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
FRONTEND_URL=http://localhost:5173

# Firebase Admin SDK
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_AQUI\n-----END PRIVATE KEY-----\n"

# Wompi
WOMPI_PUBLIC_KEY=pub_test_xxxxxxxxxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxxxxxxxxx
WOMPI_BASE_URL=https://sandbox.wompi.co/v1
WOMPI_WEBHOOK_SECRET=tu-secreto-de-eventos-wompi

# Brevo (correo transaccional)
BREVO_API_KEY=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
BREVO_SENDER_EMAIL=noreply@construescala.com
BREVO_SENDER_NAME=CONSTRUESCALA-Hospitality
BREVO_WEBHOOK_KEY=tu-secreto-webhook-brevo

# Brevo Template IDs (crear en panel Brevo → Transactional → Templates)
BREVO_TEMPLATE_BOOKING_GUEST=1
BREVO_TEMPLATE_BOOKING_HOST=2
BREVO_TEMPLATE_PAYOUT=3
BREVO_TEMPLATE_CANCEL=4
BREVO_TEMPLATE_REVIEW=5
BREVO_TEMPLATE_KYC_APPROVED=6
BREVO_TEMPLATE_KYC_REJECTED=7

# Tareas programadas (cron de Hostinger)
CRON_SECRET=genera-uno-con-openssl-rand-hex-32

# Tasas de cambio
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/COP

# Monitoreo (opcional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
