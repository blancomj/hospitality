# ============================================
# CONSTRUESCALA Hospitality — Frontend
#
# Plantilla versionada en git. Cópiala a `.env` (ignorado) para uso local.
#
# Las claves VITE_FIREBASE_* son públicas por diseño.
# Se obtienen en: Consola de Firebase > Configuración del proyecto > General >
# Tus apps > App web > Configuración del SDK.
# ============================================

VITE_FIREBASE_API_KEY=AIzaSy...tu-api-key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef1234567890

# API base. En desarrollo se usa el proxy de Vite.
VITE_API_URL=/api/v1

# NOTA: VITE_GOOGLE_CLIENT_ID ya no se usa. El login con Google va por Firebase.
